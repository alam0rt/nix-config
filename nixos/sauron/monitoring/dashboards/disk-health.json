{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "title": "Disk Temperatures",
      "type": "stat",
      "targets": [
        {
          "expr": "smartctl_device_temperature{temperature_type=\"current\"}",
          "legendFormat": "{{device}} ({{model_name}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "title": "Reallocated Sectors",
      "type": "stat",
      "targets": [
        {
          "expr": "smartctl_device_smartctl_attribute_current{attribute_name=\"Reallocated_Sector_Ct\"} or smartctl_device_attribute{attribute_name=\"Reallocated_Sector_Ct\"}",
          "legendFormat": "{{device}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "title": "Power-On Hours",
      "type": "stat",
      "targets": [
        {
          "expr": "smartctl_device_power_on_seconds",
          "legendFormat": "{{device}} ({{model_name}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Disk Temperature Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "smartctl_device_temperature{temperature_type=\"current\"}",
          "legendFormat": "{{device}} ({{model_name}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "bool_yes_no",
          "mappings": [
            { "options": { "0": { "text": "FAILING", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 26 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "title": "SMART Health Status",
      "type": "stat",
      "targets": [
        {
          "expr": "smartctl_device_smart_healthy",
          "legendFormat": "{{device}} ({{model_name}})"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["disk", "smart", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Disk Health (SMART)",
  "uid": "disk-health"
}
