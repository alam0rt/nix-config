        { "expr": "node_systemd_unit_state{name=\"home-assistant.service\",state=\"active\"}", "legendFormat": "home-assistant" },
        { "expr": "node_systemd_unit_state{name=\"vaultwarden.service\",state=\"active\"}", "legendFormat": "vaultwarden" },
        { "expr": "node_systemd_unit_state{name=\"mosquitto.service\",state=\"active\"}", "legendFormat": "mosquitto" },
