        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "title": "Failed Units",
      "type": "stat",
      "targets": [
        {
          "expr": "node_systemd_unit_state{state=\"failed\"} == 1",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Systemd Units by State",
      "type": "timeseries",
      "targets": [
        { "expr": "count(node_systemd_unit_state{state=\"active\"} == 1)", "legendFormat": "active" },
        { "expr": "count(node_systemd_unit_state{state=\"failed\"} == 1)", "legendFormat": "failed" },
        { "expr": "count(node_systemd_unit_state{state=\"inactive\"} == 1)", "legendFormat": "inactive" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["systemd", "services"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "title": "Systemd Services",
  "uid": "systemd-services"
